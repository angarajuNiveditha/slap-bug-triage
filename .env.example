# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── Jira (REQUIRED — both pipelines) ──────────────────────────────────────────
# Generate a token at: id.atlassian.net → Security → API tokens
JIRA_EMAIL=your.email@flipkart.com
JIRA_TOKEN=your_atlassian_api_token_here
JIRA_BASE_URL=https://flipkart.atlassian.net
JIRA_PROJECT=FLIPPI

# ── Local ticket store (REQUIRED — Streamlit UI + dashboard) ──────────────────
# SQLite: zero-setup, works immediately after clone.
DATABASE_URL=sqlite:///data/tickets.db
# MySQL: production-POC mode. Requires a running MySQL instance.
#   brew install mysql && brew services start mysql
#   mysql -u root -e "CREATE DATABASE slap_triage;"
# DATABASE_URL=mysql+pymysql://root@localhost/slap_triage

# ── Flipkart internal Gemini proxy (OPTIONAL — media sub-agent fast path) ─────
# Required only when triaging bugs with screenshots or screen recordings.
# If absent, the media sub-agent falls back to Claude-direct vision (no
# functional difference in output, ~2x slower).
#
# GEMINI_API_URL : full endpoint, e.g. http://10.83.64.112/gemini-2.5-flash/:generateContent
# GEMINI_API_KEY : APIM subscription key (Ocp-Apim-Subscription-Key header)
# GENVOY_TOKEN   : short-lived Genvoy JWT — expires ~hourly, re-fetch from
#                  the Genvoy developer portal when you see a 401
GEMINI_API_URL=http://10.83.64.112/gemini-2.5-flash/:generateContent
GEMINI_API_KEY=your_apim_subscription_key_here
GENVOY_TOKEN=your_genvoy_jwt_here

# ── GitHub Enterprise (OPTIONAL — repo_context / build_repo_skills.py) ────────
# Needed only if you want to re-generate the architecture skill files under
# slap_context/architecture/repos/ from the live SLAP codebase.
# The pre-generated skill files are already committed; most users can leave
# this blank.
GITHUB_FK_TOKEN=your_github_enterprise_token_here
GITHUB_FK_ORG=flipkart-incubator

# ── Anthropic SDK (OPTIONAL — main.py reference pipeline only) ────────────────
# Not needed for run_multi_agent.py or run_agent.py.
# Blocked on Flipkart corp network (console.anthropic.com is restricted).
ANTHROPIC_API_KEY=
