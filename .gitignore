# Secrets — never commit
.env

# Generated outputs
output/
output_claude/

# Active-learning corrections — contains real bug text from reviewer
# overrides. Treat as local-only training data.
data/corrections.csv

# Local ticket store (see src/db.py). MySQL data files never touch disk
# in this repo, but the CSV mirrors do — real bug data, not committed.
data/tickets.db
data/tickets_events.csv
data/tickets_snapshot.csv

# Cached embedding index (rebuilt by build_embedding_index.py)
data/embedding_index.npz
data/embedding_index_logreg.pkl
data/embedding_index_team_roster.json

# Cloned SLAP code repos (contain proprietary code — never commit)
data/repos/

# Per-repo skill files — these ARE committed so mentors / new contributors
# don't need to clone the proprietary SLAP repos or run build_repo_skills.py
# to get the architecture context. Only the .DS_Store inside the folder is
# excluded so it doesn't slip in.
slap_context/architecture/repos/.DS_Store

# Backend label-noise audit output — contains real bug titles, reporter
# emails, and Google Chat links. Treat as local-only.
audit_backend_misclassifications.md

# Python artifacts
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
.venv/
venv/

# OS / IDE
.DS_Store
.idea/
.vscode/

# sentence-transformers model cache
.cache/

# slap_context/reference_screens/ — SLAP design references (Figma-exported
# PNGs). Now COMMITTED so the media sub-agent has its visual reference set
# right after a clone, without needing access to the Figma source.

# Bug attachment images + videos — gitignored because the demo copies them
# from slap_context (unreleased designs) and the video recordings can be
# large. The email.txt files inside data/bug_with_media/ ARE committed;
# only the media stays local.
data/bug_with_media/**/*.png
data/bug_with_media/**/*.jpg
data/bug_with_media/**/*.jpeg
data/bug_with_media/**/*.webp
data/bug_with_media/**/*.gif
data/bug_with_media/**/*.mp4
data/bug_with_media/**/*.mov
data/bug_with_media/**/*.webm
data/bug_with_media/**/*.avi
data/bug_with_media/**/*.mkv
data/bug_with_media/**/*.m4v
